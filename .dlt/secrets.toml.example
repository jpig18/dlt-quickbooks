# Copy to .dlt/secrets.toml (gitignored) and fill in values from your Intuit
# developer app (https://developer.intuit.com). Mint the initial refresh token
# with Intuit's OAuth 2.0 Playground.
[sources.quickbooks]
client_id = ""
client_secret = ""
refresh_token = ""
realm_id = ""

# "sandbox" or "production" (default: production)
environment = "sandbox"

# QuickBooks refresh tokens ROTATE (~daily). The source persists the rotated
# token to this file so refreshes keep working across runs.
# token_store_path = "qbo_token.json"
